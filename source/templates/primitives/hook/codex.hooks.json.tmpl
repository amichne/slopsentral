{
  "$schema": "https://json.schemastore.org/codex-hooks.json",
  "description": "{{description}}",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/{{name}}.py --repo .",
            "timeout": 30,
            "statusMessage": "Running {{title}}"
          }
        ]
      }
    ]
  }
}
