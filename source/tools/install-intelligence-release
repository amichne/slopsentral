#!/usr/bin/env bash

set -euo pipefail

usage='source/tools/install-intelligence-release <version> <platform> <install-directory>'

print_help() {
  printf '%s\n' \
    'description: Install and verify one first-party intelligence release asset' \
    "usage: $usage" \
    'arguments[3]{name,description}:' \
    '  version,Exact release tag such as v0.2.3' \
    '  platform,One of linux-x64 linux-arm64 macos-x64 macos-arm64' \
    '  install-directory,New absolute directory that will contain the binaries'
}

usage_error() {
  printf 'error: %s\nhelp: %s\n' "$1" "$usage"
  exit 2
}

operation_error() {
  printf 'error: %s\n' "$1"
  exit 1
}

if [ "$#" -eq 1 ] && [ "$1" = '--help' ]; then
  print_help
  exit 0
fi
if [ "$#" -ne 3 ]; then
  usage_error 'version, platform, and install directory are required'
fi

version=$1
platform=$2
install_dir=$3

if ! printf '%s\n' "$version" | grep -Eq '^v(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)\.(0|[1-9][0-9]*)$'; then
  usage_error "invalid release version: $version"
fi
case "$platform" in
  linux-x64|linux-arm64|macos-x64|macos-arm64) ;;
  *) usage_error "unsupported release platform: $platform" ;;
esac
case "$install_dir" in
  /*) ;;
  *) usage_error 'install directory must be absolute' ;;
esac
if [ -e "$install_dir" ]; then
  operation_error "install directory already exists: $install_dir"
fi

for dependency in gh grep mktemp sha256sum tar; do
  if ! command -v "$dependency" >/dev/null 2>&1; then
    operation_error "required command is unavailable: $dependency"
  fi
done

release_dir=$(mktemp -d "${TMPDIR:-/tmp}/intelligence-release.XXXXXX") ||
  operation_error 'could not create a temporary release directory'
cleanup() {
  rm -rf -- "$release_dir"
}
trap cleanup EXIT HUP INT TERM

archive="intelligence-${version}-${platform}.tar.gz"
if ! gh release download "$version" \
  --repo amichne/intelligence \
  --pattern "$archive" \
  --pattern SHA256SUMS \
  --dir "$release_dir"; then
  operation_error "could not download intelligence release $version for $platform"
fi

checksum_line=$(grep -F "  $archive" "$release_dir/SHA256SUMS" || true)
if [ -z "$checksum_line" ]; then
  operation_error "published checksums do not contain $archive"
fi
if ! (
  cd "$release_dir"
  printf '%s\n' "$checksum_line" | sha256sum --check --strict -
); then
  operation_error "checksum verification failed for $archive"
fi

if ! mkdir -p "$install_dir"; then
  operation_error "could not create install directory: $install_dir"
fi
if ! tar -xzf "$release_dir/$archive" -C "$install_dir"; then
  operation_error "could not extract $archive"
fi
if [ ! -f "$install_dir/intelligence" ]; then
  operation_error "release archive does not contain the intelligence binary: $archive"
fi
chmod +x "$install_dir/intelligence"

actual_version=$("$install_dir/intelligence" --version) ||
  operation_error 'installed intelligence binary did not report its version'
expected_version="intelligence version $version"
if [ "$actual_version" != "$expected_version" ]; then
  operation_error "installed version mismatch: expected $expected_version, received $actual_version"
fi

printf 'binary: %s\nversion: %s\nplatform: %s\n' \
  "$install_dir/intelligence" \
  "$version" \
  "$platform"
