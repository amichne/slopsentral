{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slopsentral.dev/schemas/github-ci-operations/workflow-graph-model.schema.json",
  "title": "Deterministic workflow graph comparison",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "baseline",
    "candidate",
    "expectations"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "schemaVersion": {
      "const": 1
    },
    "provenance": {
      "$ref": "#/$defs/provenance"
    },
    "baseline": {
      "$ref": "#/$defs/plan"
    },
    "candidate": {
      "$ref": "#/$defs/plan"
    },
    "expectations": {
      "$ref": "#/$defs/expectations"
    }
  },
  "$defs": {
    "positiveSeconds": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "nonNegativeSeconds": {
      "type": "number",
      "minimum": 0
    },
    "identifier": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9._:/-]*$"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "observedAt",
        "source",
        "baselineRunIds",
        "candidateRunIds"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "observedAt": {
          "type": "string",
          "format": "date"
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "baselineRunIds": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "uniqueItems": true
        },
        "candidateRunIds": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "uniqueItems": true
        }
      }
    },
    "plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tasks",
        "fanoutGateTaskIds",
        "observedWorkflowDurationSamplesSeconds"
      ],
      "properties": {
        "tasks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/task"
          }
        },
        "fanoutGateTaskIds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        },
        "observedWorkflowDurationSamplesSeconds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/positiveSeconds"
          }
        }
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "needs",
        "outputs",
        "durationSamplesSeconds",
        "executionClass"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/identifier"
        },
        "needs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        },
        "outputs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/identifier"
          },
          "uniqueItems": true
        },
        "durationSamplesSeconds": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/positiveSeconds"
          }
        },
        "executionClass": {
          "enum": [
            "static",
            "toolchain",
            "gradle-cache",
            "oci",
            "artifact-consumer",
            "release",
            "other"
          ]
        }
      }
    },
    "expectations": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "outputEquivalence",
        "timingEvidenceMode",
        "minimumCriticalPathReductionSeconds",
        "maximumCandidateCriticalPathSeconds",
        "minimumFanoutGateReductionSeconds",
        "maximumCandidateFanoutGateSeconds",
        "maximumCandidateTaskCountIncrease",
        "maximumMedianModelDriftRatio",
        "minimumTaskSamples",
        "minimumWorkflowSamples"
      ],
      "properties": {
        "outputEquivalence": {
          "const": "exact"
        },
        "timingEvidenceMode": {
          "enum": [
            "blocking",
            "provisional"
          ]
        },
        "minimumCriticalPathReductionSeconds": {
          "$ref": "#/$defs/nonNegativeSeconds"
        },
        "maximumCandidateCriticalPathSeconds": {
          "$ref": "#/$defs/positiveSeconds"
        },
        "minimumFanoutGateReductionSeconds": {
          "$ref": "#/$defs/nonNegativeSeconds"
        },
        "maximumCandidateFanoutGateSeconds": {
          "$ref": "#/$defs/positiveSeconds"
        },
        "maximumCandidateTaskCountIncrease": {
          "type": "integer",
          "minimum": 0
        },
        "maximumMedianModelDriftRatio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "minimumTaskSamples": {
          "type": "integer",
          "minimum": 1
        },
        "minimumWorkflowSamples": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
