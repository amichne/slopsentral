#!/usr/bin/env python3
from __future__ import annotations

import argparse
import dataclasses
import json
import subprocess
import sys
import time
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Callable, Sequence


SCRIPT_DIR = Path(__file__).resolve().parent
if str(SCRIPT_DIR) not in sys.path:
    sys.path.insert(0, str(SCRIPT_DIR))

import ci_actions_observer as observer  # noqa: E402


@dataclass(frozen=True)
class CommandResult:
    exit_code: int
    payload: dict[str, Any]


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        description="Await meaningful GitHub Actions events through gh-axi.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    parser.add_argument("--repo", default=".", help="Path inside the target Git repository.")
    subcommands = parser.add_subparsers(dest="command", required=True)

    arm = subcommands.add_parser("arm", help="Record a baseline and arm one observation.")
    target = arm.add_mutually_exclusive_group(required=True)
    target.add_argument("--run-id", help="GitHub Actions run database ID.")
    target.add_argument(
        "--pr",
        help="Positive PR number or GitHub PR URL.",
    )
    arm.add_argument(
        "--until",
        choices=[predicate.value for predicate in observer.WaitPredicate],
        default=observer.WaitPredicate.TERMINAL.value,
    )
    arm.add_argument(
        "--timeout",
        default="auto",
        help="Seconds from 30 through 3300, or auto for duration-informed selection.",
    )
    arm.add_argument("--required", action="store_true", help="Observe required PR checks only.")
    arm.add_argument("--json", action="store_true")

    await_parser = subcommands.add_parser("await", help="Wait for the armed observation event.")
    await_parser.add_argument("--json", action="store_true")

    status = subcommands.add_parser("status", help="Show whether an observation is armed.")
    status.add_argument("--json", action="store_true")

    profile_parser = subcommands.add_parser("profile", help="Inspect or export duration knowledge.")
    profile_commands = profile_parser.add_subparsers(dest="profile_command", required=True)
    profile_show = profile_commands.add_parser("show")
    profile_show.add_argument("--json", action="store_true")
    profile_export = profile_commands.add_parser("export")
    profile_export.add_argument("--output", type=Path)
    profile_export.add_argument("--json", action="store_true")
    return parser


def execute(
    argv: Sequence[str],
    *,
    runner: observer.AxiRunner = observer.run_gh_axi,
    store: observer.StateStore | None = None,
    now_epoch: Callable[[], float] = time.time,
    sleeper: Callable[[float], None] = time.sleep,
) -> CommandResult:
    parser = build_parser()
    try:
        args = parser.parse_args(list(argv))
        repo_root = store.repo_root if store is not None else find_repo_root(Path(args.repo))
        state = store or observer.StateStore(repo_root)
        if args.command == "arm":
            return arm_observation(args, repo_root, state, runner, now_epoch)
        if args.command == "await":
            return await_observation(repo_root, state, runner, now_epoch, sleeper)
        if args.command == "status":
            active = state.load_active()
            if active is None:
                return CommandResult(0, {"state": "idle"})
            return CommandResult(
                0,
                {"state": "armed", "request": observer.active_request_to_json(active)},
            )
        if args.command == "profile" and args.profile_command == "show":
            return CommandResult(0, observer.build_duration_profile(state.load_history()))
        if args.command == "profile" and args.profile_command == "export":
            return CommandResult(0, state.export_profile(args.output))
        raise observer.ObserverError(f"unsupported command: {args.command}")
    except observer.ObserverError as exc:
        return CommandResult(2, {"outcome": "error", "error": str(exc)})


def arm_observation(
    args: argparse.Namespace,
    repo_root: Path,
    store: observer.StateStore,
    runner: observer.AxiRunner,
    now_epoch: Callable[[], float],
) -> CommandResult:
    target = target_from_args(args)
    baseline = observer.fetch_snapshot(target, repo_root, runner)
    timeout = resolve_timeout(args.timeout, store, baseline, repo_root)
    armed_epoch = now_epoch()
    request = observer.ActiveRequest(
        target=target,
        predicate=observer.WaitPredicate(args.until),
        baseline=baseline,
        timeout=timeout,
        armed_at=observer.iso_from_epoch(armed_epoch),
        expires_at=observer.iso_from_epoch(armed_epoch + timeout.seconds),
    )
    if baseline.outcome != observer.Outcome.PENDING:
        result = observer.WaitResult(
            target=target,
            predicate=request.predicate,
            outcome=baseline.outcome,
            previous=baseline,
            current=baseline,
            polls=1,
            started_at=request.armed_at,
            finished_at=request.armed_at,
            timeout=timeout,
            failure_logs=fetch_failure_logs(target, repo_root, runner, baseline),
        )
        store.write_last_observation(result)
        record_duration_if_available(result, repo_root, store, runner)
        return CommandResult(exit_code_for(result.outcome), observer.wait_result_to_json(result))
    store.arm(request)
    return CommandResult(
        0,
        {
            "state": "armed",
            "request": observer.active_request_to_json(request),
            "timeout": dataclasses.asdict(timeout),
            "statePath": str(store.active_path),
        },
    )


def await_observation(
    repo_root: Path,
    store: observer.StateStore,
    runner: observer.AxiRunner,
    now_epoch: Callable[[], float],
    sleeper: Callable[[float], None],
) -> CommandResult:
    request = store.load_active()
    if request is None:
        raise observer.ObserverError("no GitHub Actions observation is armed")
    try:
        result = observer.await_event(
            request,
            fetch=lambda target: observer.fetch_snapshot(target, repo_root, runner),
            now_epoch=now_epoch,
            sleeper=sleeper,
        )
        if result.outcome == observer.Outcome.FAILURE:
            result = dataclasses.replace(
                result,
                failure_logs=fetch_failure_logs(
                    result.target,
                    repo_root,
                    runner,
                    result.current,
                ),
            )
        store.write_last_observation(result)
        record_duration_if_available(result, repo_root, store, runner)
    except observer.ObserverError as exc:
        now = observer.iso_from_epoch(now_epoch())
        result = observer.WaitResult(
            target=request.target,
            predicate=request.predicate,
            outcome=observer.Outcome.ERROR,
            previous=request.baseline,
            current=request.baseline,
            polls=0,
            started_at=request.armed_at,
            finished_at=now,
            timeout=request.timeout,
            failure_logs=[],
            error=str(exc),
        )
        store.write_last_observation(result)
        store.clear_active()
        return CommandResult(2, observer.wait_result_to_json(result))
    store.clear_active()
    return CommandResult(exit_code_for(result.outcome), observer.wait_result_to_json(result))


def resolve_timeout(
    value: str,
    store: observer.StateStore,
    baseline: observer.Snapshot,
    repo_root: Path,
) -> observer.TimeoutRecommendation:
    if value != "auto":
        try:
            seconds = int(value)
        except ValueError as exc:
            raise observer.ObserverError("--timeout must be auto or an integer") from exc
        if seconds < 30 or seconds > 3300:
            raise observer.ObserverError("--timeout must be between 30 and 3300 seconds")
        return observer.TimeoutRecommendation(seconds, "explicit", 0, None, None, None)

    workflow = str(baseline.details.get("workflow") or "")
    team_group = matching_team_profile(repo_root, workflow)
    if team_group is not None and int(team_group.get("sampleCount", 0)) >= 5:
        p95 = int(team_group["p95Seconds"])
        seconds = min(3300, max(300, int(p95 * 1.5 + 60)))
        return observer.TimeoutRecommendation(
            seconds=seconds,
            source="team-profile",
            sample_count=int(team_group["sampleCount"]),
            p50_seconds=int(team_group["p50Seconds"]),
            p95_seconds=p95,
            maximum_seconds=int(team_group["maximumSeconds"]),
        )

    matching_samples = [
        sample
        for sample in store.load_history()
        if not workflow or sample.workflow == workflow
    ]
    durations = observer.eligible_durations(matching_samples)
    return observer.recommend_timeout(
        durations,
        source="local-history" if durations else "default",
    )


def matching_team_profile(repo_root: Path, workflow: str) -> dict[str, Any] | None:
    path = repo_root / ".axi/github-actions-duration-profile.json"
    if not path.exists():
        return None
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        raise observer.ObserverError(f"team duration profile is invalid: {path}") from exc
    groups = payload.get("groups") if isinstance(payload, dict) else None
    if not isinstance(groups, list):
        raise observer.ObserverError(f"team duration profile groups must be an array: {path}")
    candidates = [
        group
        for group in groups
        if isinstance(group, dict) and (not workflow or group.get("workflow") == workflow)
    ]
    return max(candidates, key=lambda group: int(group.get("sampleCount", 0)), default=None)


def target_from_args(args: argparse.Namespace) -> observer.Target:
    if args.run_id:
        if args.required:
            raise observer.ObserverError("--required can only be used with --pr")
        return observer.Target(observer.TargetKind.RUN, str(args.run_id))
    return observer.Target(
        observer.TargetKind.PR,
        observer.pr_number(str(args.pr)),
        bool(args.required),
    )


def fetch_failure_logs(
    target: observer.Target,
    repo_root: Path,
    runner: observer.AxiRunner,
    snapshot: observer.Snapshot,
) -> list[dict[str, Any]]:
    if target.kind != observer.TargetKind.RUN or snapshot.outcome != observer.Outcome.FAILURE:
        return []
    command = [*observer.GH_AXI_PREFIX, "run", "view", target.value, "--log-failed"]
    result = runner(command, repo_root)
    if result.returncode != 0:
        return [
            {
                "runId": target.value,
                "status": "unavailable",
                "error": (result.stderr or result.stdout).strip(),
            }
        ]
    return [{"runId": target.value, "status": "ok", "output": result.stdout.strip()}]


def record_duration_if_available(
    result: observer.WaitResult,
    repo_root: Path,
    store: observer.StateStore,
    runner: observer.AxiRunner,
) -> None:
    if result.target.kind != observer.TargetKind.RUN:
        return
    if result.current.outcome == observer.Outcome.PENDING:
        return
    try:
        repository = observer.resolve_repository_slug(repo_root, runner)
        api = runner(
            [
                *observer.GH_AXI_PREFIX,
                "api",
                f"/repos/{repository}/actions/runs/{result.target.value}",
            ],
            repo_root,
        )
        observer.require_success(api, "gh-axi run API")
        details = observer.parse_run_api(api.stdout)
        observer.record_terminal_duration(store, details, repository=repository)
    except observer.ObserverError:
        return


def find_repo_root(start: Path) -> Path:
    cwd = start.resolve()
    process = subprocess.run(
        ["git", "rev-parse", "--show-toplevel"],
        cwd=cwd,
        text=True,
        capture_output=True,
    )
    if process.returncode != 0:
        raise observer.ObserverError(f"not inside a Git repository: {cwd}")
    return Path(process.stdout.strip()).resolve()


def exit_code_for(outcome: observer.Outcome) -> int:
    if outcome == observer.Outcome.FAILURE:
        return 1
    if outcome == observer.Outcome.TIMEOUT:
        return 124
    if outcome == observer.Outcome.ERROR:
        return 2
    return 0


def render_text(payload: dict[str, Any]) -> str:
    if payload.get("state") == "idle":
        return "state: idle"
    return json.dumps(payload, indent=2, sort_keys=True)


def main() -> int:
    result = execute(sys.argv[1:])
    json_requested = "--json" in sys.argv[1:]
    output = json.dumps(result.payload, indent=2, sort_keys=True) if json_requested else render_text(result.payload)
    stream = sys.stderr if result.exit_code == 2 else sys.stdout
    print(output, file=stream)
    return result.exit_code


if __name__ == "__main__":
    raise SystemExit(main())
