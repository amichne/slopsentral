#!/usr/bin/env python3
from __future__ import annotations

import argparse
import errno
import hashlib
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
import xml.etree.ElementTree as ET
from dataclasses import dataclass, replace
from enum import IntEnum
from pathlib import Path
from typing import Any, Callable, Mapping, Sequence


DESCRIPTION = "Develop and validate typed Pkl configuration"
SUPPORTED_VERSION = ">=0.32.0,<0.33.0"
VERSION_PATTERN = re.compile(r"(?:Pkl\s+)?(?P<major>\d+)\.(?P<minor>\d+)\.(?P<patch>\d+)")
NUMBER_PATTERN = re.compile(r"-?(?:0|[1-9]\d*)(?:\.\d+)?(?:[eE][+-]?\d+)?$")
SAFE_MODULES = "pkl:,file:,modulepath:,repl:,package:,projectpackage:"
SAFE_RESOURCES = "prop:,package:,projectpackage:"
PREVIEW_CHARS = 1200


class ExitCode(IntEnum):
    OK = 0
    ERROR = 1
    USAGE = 2


class UsageError(Exception):
    def __init__(self, message: str, command: tuple[str, ...] = ()) -> None:
        super().__init__(message)
        self.command = command


class AxiParser(argparse.ArgumentParser):
    def error(self, message: str) -> None:
        raise UsageError(message)


@dataclass(frozen=True)
class Context:
    workspace: Path
    pkl_bin: str
    timeout_seconds: int
    policy: str
    allow_env: tuple[str, ...]
    properties: tuple[str, ...]
    allow_modules: tuple[str, ...]
    allow_resources: tuple[str, ...]
    full: bool


@dataclass(frozen=True)
class ProcessResult:
    exit_code: int
    stdout: str
    stderr: str


Runner = Callable[[Sequence[str], Path, int], ProcessResult]


