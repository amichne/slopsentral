{
  "schemaVersion": 1,
  "sources": [
    {
      "id": "pkl",
      "repository": "https://github.com/apple/pkl",
      "branch": "main",
      "role": "Language, CLI, standard library, tests, and core documentation sources",
      "include": [
        "README.adoc",
        "docs/**/*.adoc",
        "stdlib/**/*.pkl"
      ]
    },
    {
      "id": "pkl-lang-org",
      "repository": "https://github.com/apple/pkl-lang.org",
      "branch": "main",
      "role": "Source for the official Pkl documentation website",
      "include": [
        "README.md",
        "src/**/*.md",
        "src/**/*.adoc"
      ]
    },
    {
      "id": "pkl-evolution",
      "repository": "https://github.com/apple/pkl-evolution",
      "branch": "main",
      "role": "Accepted and proposed language evolution documents",
