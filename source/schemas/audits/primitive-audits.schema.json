{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slopsentral.local/schemas/audits/primitive-audits.schema.json",
  "title": "Primitive Audit Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "type",
    "schemaVersion",
    "marketplace",
    "entries"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "const": "PRIMITIVE_AUDIT_MANIFEST"
    },
    "schemaVersion": {
      "const": 1
    },
    "marketplace": {
      "type": "string",
      "minLength": 1
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/auditEntry"
      }
    }
  },
  "$defs": {
    "auditEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "id",
        "target",
        "baseline",
        "decision",
        "confidence",
        "reviewedAt",
        "reviewedBy",
        "capabilityBoundary",
        "schemaCoverage",
        "provenance",
        "validation",
        "runtimeSafety",
        "residualRisks",
        "nextAction"
      ],
      "allOf": [
        {
          "if": {
            "properties": {
              "decision": {
                "const": "PROMOTE_READY"
              }
            }
          },
          "then": {
            "properties": {
              "capabilityBoundary": {
                "properties": {
                  "status": {
                    "const": "PASS"
                  }
                }
              },
              "schemaCoverage": {
                "properties": {
                  "status": {
                    "const": "PASS"
                  }
                }
              },
              "provenance": {
                "properties": {
                  "status": {
                    "const": "PASS"
                  }
                }
              },
              "validation": {
                "properties": {
                  "status": {
                    "const": "PASS"
                  }
                }
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "decision": {
                "const": "ACTIVATE_READY"
              }
            }
          },
          "then": {
            "properties": {
              "runtimeSafety": {
                "properties": {
                  "status": {
                    "const": "PASS"
                  }
                }
              }
            }
          }
        }
      ],
      "properties": {
        "type": {
          "const": "PRIMITIVE_AUDIT"
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]+$"
        },
        "target": {
          "$ref": "#/$defs/auditTarget"
        },
        "baseline": {
          "type": "string",
          "minLength": 1
        },
        "decision": {
          "type": "string",
          "enum": [
            "PROMOTE_READY",
            "SYNTHESIZE_FIRST",
            "REWRITE_FIRST",
            "DEFER",
            "ACTIVATE_READY",
            "CLEANUP_READY",
            "IGNORE"
          ]
        },
        "confidence": {
          "type": "string",
          "enum": [
            "LOW",
            "MEDIUM",
            "HIGH"
          ]
        },
        "reviewedAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "reviewedBy": {
          "type": "string",
          "minLength": 1
        },
        "capabilityBoundary": {
          "$ref": "#/$defs/evidenceBlock"
        },
        "schemaCoverage": {
          "$ref": "#/$defs/evidenceBlock"
        },
        "provenance": {
          "$ref": "#/$defs/provenanceBlock"
        },
        "validation": {
          "$ref": "#/$defs/validationBlock"
        },
        "runtimeSafety": {
          "$ref": "#/$defs/evidenceBlock"
        },
        "residualRisks": {
          "$ref": "#/$defs/nonEmptyStrings"
        },
        "nextAction": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "auditTarget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "name",
        "paths"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "AGENT",
            "EVAL_FAMILY",
            "HOOK",
            "PLUGIN",
            "PROFILE",
            "SKILL"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "paths": {
          "$ref": "#/$defs/relativePaths"
        }
      }
    },
    "evidenceBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "evidence"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "PARTIAL",
            "BLOCKED"
          ]
        },
        "evidence": {
          "$ref": "#/$defs/nonEmptyStrings"
        }
      }
    },
    "provenanceBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "firstPartyCollisionCheck",
        "evidence"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "PARTIAL",
            "BLOCKED"
          ]
        },
        "firstPartyCollisionCheck": {
          "type": "string",
          "enum": [
            "NOT_APPLICABLE",
            "CHECKED_NO_COLLISION",
            "BLOCKED_COLLISION_RISK"
          ]
        },
        "evidence": {
          "$ref": "#/$defs/nonEmptyStrings"
        }
      }
    },
    "validationBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "commands"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "PARTIAL",
            "BLOCKED"
          ]
        },
        "commands": {
          "$ref": "#/$defs/nonEmptyStrings"
        }
      }
    },
    "relativePaths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1,
        "not": {
          "pattern": "^/"
        }
      }
    },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
