{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slopsentral.local/schemas/evals/routing-cases.schema.json",
  "title": "Primitive Routing Case Set",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "$schema",
    "type",
    "schemaVersion",
    "name",
    "description",
    "cases"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "type": {
      "const": "ROUTING_CASE_SET"
    },
    "schemaVersion": {
      "const": 2
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/routingCase"
      }
    }
  },
  "$defs": {
    "routingCase": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "type",
        "source",
        "prompt",
        "expectedPrimitive",
        "observedRoute",
        "allowedActions",
        "forbiddenActions",
        "recoveryExpectation",
        "productiveOutcome",
        "verificationEvidence",
        "notes"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]+$"
        },
        "type": {
          "type": "string",
          "enum": [
            "TRIGGER_MISS",
            "WRONG_PRIMITIVE",
            "LOADED_BYPASSED",
            "ADAPTER_DRIFT",
            "SCHEMA_FRICTION",
            "SETUP_FRICTION"
          ]
        },
        "source": {
          "$ref": "#/$defs/source"
        },
        "prompt": {
          "type": "string",
          "minLength": 1
        },
        "expectedPrimitive": {
          "$ref": "#/$defs/expectedPrimitive"
        },
        "observedRoute": {
          "$ref": "#/$defs/observedRoute"
        },
        "allowedActions": {
          "$ref": "#/$defs/nonEmptyStrings"
        },
        "forbiddenActions": {
          "$ref": "#/$defs/nonEmptyStrings"
        },
        "recoveryExpectation": {
          "type": "string",
          "minLength": 1
        },
        "productiveOutcome": {
          "type": "string",
          "minLength": 1
        },
        "verificationEvidence": {
          "$ref": "#/$defs/nonEmptyStrings"
        },
        "notes": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "capturedAt",
        "evidenceRefs"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "CURRENT_SOURCE",
            "MEMORY_INDEX",
            "USER_CLARIFICATION",
            "LOCAL_VALIDATION"
          ]
        },
        "capturedAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "evidenceRefs": {
          "$ref": "#/$defs/nonEmptyStrings"
        }
      }
    },
    "expectedPrimitive": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "name"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "AGENT",
            "HOOK",
            "PLUGIN",
            "PROFILE",
            "SKILL"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "observedRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "summary",
        "risk",
        "loadedPrimitives"
      ],
      "properties": {
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "risk": {
          "type": "string",
          "minLength": 1
        },
        "loadedPrimitives": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
