{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://slopsentral.local/schemas/evals/routing-field-observations.schema.json",
  "title": "Routing Field Observation Set",
  "type": "object",
  "additionalProperties": false,
  "examples": [
    {
      "$schema": "../../schemas/evals/routing-field-observations.schema.json",
      "type": "ROUTING_FIELD_OBSERVATION_SET",
      "schemaVersion": 1,
      "name": "post-readiness-field-observations",
      "description": "Sanitized observations from real workflow execution after routing readiness work.",
      "observations": [
        {
          "type": "ROUTING_FIELD_OBSERVATION",
          "id": "pr-ci-remote-check-evidence-2026-06-22",
          "caseId": "ci-failure-triage-uses-remote-check-evidence",
          "capturedAt": "2026-06-22",
          "sourceType": "PR_VALIDATION",
          "outcome": "PASS",
          "routedPrimitive": {
            "type": "SKILL",
            "name": "github-ci-operations"
          },
          "evidenceRefs": [
            "PR 5 Validate Source run 27964536885 completed successfully."
          ],
          "productiveOutcomeObserved": "Remote check evidence was read after the branch changed.",
          "followUpAction": "Keep PR checks green after future pushes.",
          "limitations": [
            "This observation proves remote check handling, not Kotlin code execution."
          ]
        }
      ]
    }
  ],
  "required": [
    "$schema",
    "type",
    "schemaVersion",
    "name",
    "description",
    "observations"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "../../schemas/evals/routing-field-observations.schema.json"
      ]
    },
    "type": {
      "type": "string",
      "enum": [
        "ROUTING_FIELD_OBSERVATION_SET"
      ],
      "examples": [
        "ROUTING_FIELD_OBSERVATION_SET"
      ]
    },
    "schemaVersion": {
      "type": "integer",
      "enum": [
        1
      ],
      "examples": [
        1
      ]
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "post-readiness-field-observations"
      ]
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "Sanitized observations from real workflow execution after routing readiness work."
      ]
    },
    "observations": {
      "type": "array",
      "minItems": 1,
      "examples": [
        [
          {
            "type": "ROUTING_FIELD_OBSERVATION",
            "id": "pr-ci-remote-check-evidence-2026-06-22",
            "caseId": "ci-failure-triage-uses-remote-check-evidence",
            "capturedAt": "2026-06-22",
            "sourceType": "PR_VALIDATION",
            "outcome": "PASS",
            "routedPrimitive": {
              "type": "SKILL",
              "name": "github-ci-operations"
            },
            "evidenceRefs": [
              "PR 5 Validate Source run 27964536885 completed successfully."
            ],
            "productiveOutcomeObserved": "Remote check evidence was read after the branch changed.",
            "followUpAction": "Keep PR checks green after future pushes.",
            "limitations": [
              "This observation proves remote check handling, not Kotlin code execution."
            ]
          }
        ]
      ],
      "items": {
        "$ref": "#/$defs/fieldObservation"
      }
    }
  },
  "$defs": {
    "fieldObservation": {
      "type": "object",
      "additionalProperties": false,
      "examples": [
        {
          "type": "ROUTING_FIELD_OBSERVATION",
          "id": "runtime-installed-state-visible-2026-06-22",
          "caseId": "plugin-install-recovery-proves-installed-state",
          "capturedAt": "2026-06-22",
          "sourceType": "RUNTIME_VERIFICATION",
          "outcome": "PASS",
          "routedPrimitive": {
            "type": "SKILL",
            "name": "repository-onboarding"
          },
          "evidenceRefs": [
            "codex plugin list reported kotlin-engineering@slopsentral installed and enabled."
          ],
          "productiveOutcomeObserved": "Provider-visible installed-state evidence was captured without editing installed caches.",
          "followUpAction": "Repeat the installed-state check in each target team environment.",
          "limitations": [
            "This does not prove the installed cache contains this branch head."
          ]
        }
      ],
      "required": [
        "type",
        "id",
        "caseId",
        "capturedAt",
        "sourceType",
        "outcome",
        "routedPrimitive",
        "evidenceRefs",
        "productiveOutcomeObserved",
        "followUpAction",
        "limitations"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "ROUTING_FIELD_OBSERVATION"
          ],
          "examples": [
            "ROUTING_FIELD_OBSERVATION"
          ]
        },
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]+$",
          "examples": [
            "runtime-installed-state-visible-2026-06-22"
          ]
        },
        "caseId": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]+$",
          "examples": [
            "plugin-install-recovery-proves-installed-state"
          ]
        },
        "capturedAt": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "examples": [
            "2026-06-22"
          ]
        },
        "sourceType": {
          "type": "string",
          "enum": [
            "LIVE_SESSION",
            "PR_VALIDATION",
            "RUNTIME_VERIFICATION",
            "TEAM_FEEDBACK"
          ],
          "examples": [
            "RUNTIME_VERIFICATION"
          ]
        },
        "outcome": {
          "type": "string",
          "enum": [
            "PASS",
            "DRIFT",
            "BLOCKED",
            "NEEDS_REPLAY_CASE"
          ],
          "examples": [
            "PASS"
          ]
        },
        "routedPrimitive": {
          "$ref": "#/$defs/primitive"
        },
        "evidenceRefs": {
          "$ref": "#/$defs/nonEmptyStrings"
        },
        "productiveOutcomeObserved": {
          "type": "string",
          "minLength": 1,
          "examples": [
            "Provider-visible installed-state evidence was captured without editing installed caches."
          ]
        },
        "followUpAction": {
          "type": "string",
          "minLength": 1,
          "examples": [
            "Repeat the installed-state check in each target team environment."
          ]
        },
        "limitations": {
          "$ref": "#/$defs/nonEmptyStrings"
        }
      }
    },
    "primitive": {
      "type": "object",
      "additionalProperties": false,
      "examples": [
        {
          "type": "SKILL",
          "name": "repository-onboarding"
        }
      ],
      "required": [
        "type",
        "name"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "AGENT",
            "HOOK",
            "PLUGIN",
            "PROFILE",
            "SKILL"
          ],
          "examples": [
            "SKILL"
          ]
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "examples": [
            "repository-onboarding"
          ]
        }
      }
    },
    "nonEmptyStrings": {
      "type": "array",
      "minItems": 1,
      "examples": [
        [
          "codex plugin list reported kotlin-engineering@slopsentral installed and enabled."
        ]
      ],
      "items": {
        "type": "string",
        "minLength": 1,
        "examples": [
          "codex plugin list reported kotlin-engineering@slopsentral installed and enabled."
        ]
      }
    }
  }
}
