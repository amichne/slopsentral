{
  "type": "WORKFLOW_PROFILE",
  "schemaVersion": 1,
  "name": "kotlin-repo-default",
  "description": "Default Kotlin repository workflow that composes baseline executable-check TDD, Kotlin-specific engineering, host-neutral Git operations, effective delivery, and Codex hook adapters without duplicate primitive ownership.",
  "marketplaces": [
    {
      "type": "WORKFLOW_MARKETPLACE",
      "name": "slopsentral",
      "provider": "codex",
      "source": "https://github.com/amichne/slopsentral",
      "entrypoint": ".agents/plugins/marketplace.json",
      "scope": "plugins in this workflow profile"
    }
  ],
  "plugins": [
    "engineering-baseline",
    "kotlin-engineering",
    "git-ci-operations",
    "effective-delivery"
  ],
  "hooks": [
    {
      "type": "WORKFLOW_HOOK",
      "name": "agents-md-turn-refresh",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "required-skill-read",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "github-actions-await",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "kotlin-horizontalization-check",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "gradle-check-green",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "gradle-wrapper-integrity",
      "adapter": "codex"
    }
  ],
  "validation": {
    "type": "WORKFLOW_VALIDATION",
    "commands": [
      "node source/tools/validate-source-graph.mjs",
      "intelligence project --source . --harness codex --out /tmp/slopsentral-codex",
      "intelligence project --source . --harness github-copilot --out /tmp/slopsentral-github-copilot"
    ]
  }
}
