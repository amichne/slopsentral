{
  "type": "WORKFLOW_PROFILE",
  "schemaVersion": 1,
  "name": "kotlin-repo-default",
  "description": "Default enterprise Kotlin repository workflow using the engineering baseline, Kotlin engineering workflow, Git/CI operations, and Codex hook adapters.",
  "marketplaces": [
    {
      "type": "WORKFLOW_MARKETPLACE",
      "name": "slopsentral",
      "provider": "codex",
      "source": "https://github.com/amichne/slopsentral",
      "entrypoint": ".agents/plugins/marketplace.json",
      "scope": "plugins in this workflow profile"
    }
  ],
  "plugins": [
    "engineering-baseline",
    "kotlin-engineering",
    "git-ci-operations"
  ],
  "hooks": [
    {
      "type": "WORKFLOW_HOOK",
      "name": "agents-md-turn-refresh",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "required-skill-read",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "kotlin-horizontalization-check",
      "adapter": "codex"
    },
    {
      "type": "WORKFLOW_HOOK",
      "name": "gradle-check-green",
      "adapter": "codex"
    }
  ],
  "validation": {
    "type": "WORKFLOW_VALIDATION",
    "commands": [
      "intelligence validate --portable"
    ]
  }
}
