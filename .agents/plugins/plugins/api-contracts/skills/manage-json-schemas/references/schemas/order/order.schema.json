{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "references/schemas/order/order.schema.json",
  "title": "ORDER",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "ORDER"
      ],
      "examples": [
        "ORDER"
      ]
    },
    "orderId": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "order-1001"
      ]
    },
    "order": {
      "oneOf": [
        {
          "$ref": "created.schema.json"
        }
      ],
      "discriminator": {
        "propertyName": "type"
      },
      "examples": [
        {
          "type": "CREATED"
        }
      ]
    }
  },
  "required": [
    "order",
    "orderId",
    "type"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "type": "ORDER",
      "orderId": "order-1001",
      "order": {
        "type": "CREATED"
      }
    }
  ]
}
