{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "references/schemas/upload/command.schema.json",
  "title": "COMMAND",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "COMMAND"
      ],
      "examples": [
        "COMMAND"
      ]
    },
    "command": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "npm test"
      ]
    },
    "cwd": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "."
      ]
    }
  },
  "required": [
    "command",
    "cwd",
    "type"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "type": "COMMAND",
      "command": "npm test",
      "cwd": "."
    }
  ]
}
