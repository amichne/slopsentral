{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "references/schemas/upload/manifest.schema.json",
  "title": "MANIFEST",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "MANIFEST"
      ],
      "examples": [
        "MANIFEST"
      ]
    },
    "storedPath": {
      "type": "string",
      "minLength": 1,
      "examples": [
        "inbox/raw/2026-05-23-compiler-gated-retrieval.md"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$",
      "examples": [
        "sha256:3a6eb0790f39ac87c94f3856b2dd2c5d110e6811602261a9a923d3bb23adc8b7"
      ]
    }
  },
  "required": [
    "sha256",
    "storedPath",
    "type"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "type": "MANIFEST",
      "storedPath": "inbox/raw/2026-05-23-compiler-gated-retrieval.md",
      "sha256": "sha256:3a6eb0790f39ac87c94f3856b2dd2c5d110e6811602261a9a923d3bb23adc8b7"
    }
  ]
}
