{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "references/schemas/upload/upload.schema.json",
  "title": "UPLOAD",
  "type": "object",
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "UPLOAD"
      ],
      "examples": [
        "UPLOAD"
      ]
    },
    "id": {
      "type": "string",
      "pattern": "^upload_[0-9]{8}_[0-9]{6}_[a-z0-9]+(?:_[a-z0-9]+)*$",
      "examples": [
        "upload_20260523_153012_compiler_gated_retrieval"
      ]
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "examples": [
        "2026-05-23T15:30:12-04:00"
      ]
    },
    "upload": {
      "oneOf": [
        {
          "$ref": "command.schema.json"
        },
        {
          "$ref": "manifest.schema.json"
        }
      ],
      "discriminator": {
        "propertyName": "type"
      },
      "examples": [
        {
          "type": "MANIFEST",
          "storedPath": "inbox/raw/2026-05-23-compiler-gated-retrieval.md",
          "sha256": "sha256:3a6eb0790f39ac87c94f3856b2dd2c5d110e6811602261a9a923d3bb23adc8b7"
        }
      ]
    }
  },
  "required": [
    "createdAt",
    "id",
    "type",
    "upload"
  ],
  "additionalProperties": false,
  "examples": [
    {
      "type": "UPLOAD",
      "id": "upload_20260523_153012_compiler_gated_retrieval",
      "createdAt": "2026-05-23T15:30:12-04:00",
      "upload": {
        "type": "MANIFEST",
        "storedPath": "inbox/raw/2026-05-23-compiler-gated-retrieval.md",
        "sha256": "sha256:3a6eb0790f39ac87c94f3856b2dd2c5d110e6811602261a9a923d3bb23adc8b7"
      }
    }
  ]
}
