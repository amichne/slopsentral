{
  "$schema": "https://json.schemastore.org/codex-hooks.json",
  "description": "Run a Gradle green check at turn end when Kotlin or Gradle-owned files changed.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash hooks/gradle-check-green.sh --repo .",
            "timeout": 1800,
            "statusMessage": "Checking Gradle green state"
          }
        ]
      }
    ]
  }
}
