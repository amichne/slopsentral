#!/usr/bin/env python3
from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
from dataclasses import dataclass
from pathlib import Path
from typing import Any, Iterable, Mapping, Sequence


DESCRIPTION = "Sync and index declared first-party Pkl sources"
DEFAULT_MANIFEST = Path(__file__).resolve().parents[1] / "references" / "official-sources.json"
FIRST_PARTY_PREFIX = "https://github.com/apple/"
HEADING_PATTERN = re.compile(r"^(?:#{1,6}|={1,6})\s+(.+?)\s*$")
NUMBER_PATTERN = re.compile(r"-?(?:0|[1-9]\d*)(?:\.\d+)?(?:[eE][+-]?\d+)?$")
PKL_PATTERNS = (
    ("module", re.compile(r"^\s*(?:(?:open|abstract)\s+)?module\s+([A-Za-z_][A-Za-z0-9_.]*)")),
    ("class", re.compile(r"^\s*(?:(?:open|abstract|local)\s+)*class\s+([A-Za-z_][A-Za-z0-9_]*)")),
    ("typealias", re.compile(r"^\s*(?:(?:local|const)\s+)*typealias\s+([A-Za-z_][A-Za-z0-9_]*)")),
)


class UsageError(Exception):
    pass


class AxiParser(argparse.ArgumentParser):
    def error(self, message: str) -> None:
        raise UsageError(message)


@dataclass(frozen=True)
class Source:
    id: str
    repository: str
    branch: str
    role: str
    include: tuple[str, ...]


def quote(value: object) -> str:
    text = str(value)
    if (
        text
        and text == text.strip()
        and text not in {"true", "false", "null"}
        and not NUMBER_PATTERN.fullmatch(text)
        and not text.startswith("-")
        and not any(character in text for character in ',:[]{}"\\\n\r\t')
        and all(ord(character) >= 0x20 for character in text)
    ):
        return text
    return json.dumps(text, ensure_ascii=False)


def emit(payload: Mapping[str, Any]) -> None:
    lines: list[str] = []
    for key, value in payload.items():
        if isinstance(value, bool):
            lines.append(f"{key}: {'true' if value else 'false'}")
        elif isinstance(value, (int, float)):
            lines.append(f"{key}: {value}")
        elif value is None:
            lines.append(f"{key}: null")
        elif isinstance(value, list) and all(isinstance(item, dict) for item in value):
            if not value:
                lines.append(f"{key}[0]:")
                continue
            fields = list(value[0])
            lines.append(f"{key}[{len(value)}]{{{','.join(fields)}}}:")
            for item in value:
                lines.append("  " + ",".join(quote(item[field]) for field in fields))
        elif isinstance(value, list):
            lines.append(f"{key}[{len(value)}]: " + ",".join(quote(item) for item in value))
        else:
            lines.append(f"{key}: {quote(value)}")
    sys.stdout.write("\n".join(lines))


def build_parser() -> AxiParser:
    parser = AxiParser(description=DESCRIPTION, allow_abbrev=False)
    subcommands = parser.add_subparsers(dest="command")

    catalog = subcommands.add_parser(
        "catalog",
        help="List declared source repositories without network access",
        allow_abbrev=False,
    )
    catalog.add_argument("--manifest", type=Path, default=DEFAULT_MANIFEST)
    catalog.add_argument("--source", action="append", default=[])

    sync = subcommands.add_parser(
        "sync",
        help="Clone or update exact source checkouts and write a commit lock",
        allow_abbrev=False,
    )
    sync.add_argument("--manifest", type=Path, default=DEFAULT_MANIFEST)
    sync.add_argument("--cache", type=Path, required=True)
    sync.add_argument("--source", action="append", default=[])
    sync.add_argument("--allow-local-sources", action="store_true")

    index = subcommands.add_parser(
        "index",
        help="Parse a synced cache into a deterministic JSON reference index",
        allow_abbrev=False,
    )
    index.add_argument("--manifest", type=Path, default=DEFAULT_MANIFEST)
    index.add_argument("--cache", type=Path, required=True)
    index.add_argument("--out", type=Path, required=True)
    index.add_argument("--source", action="append", default=[])
    return parser


def load_sources(path: Path) -> list[Source]:
    try:
        payload = json.loads(path.read_text(encoding="utf-8"))
    except FileNotFoundError as error:
        raise UsageError(f"manifest does not exist: {path}") from error
    except json.JSONDecodeError as error:
        raise UsageError(f"manifest is not valid JSON: {path}: {error}") from error
    if not isinstance(payload, dict) or payload.get("schemaVersion") != 1:
        raise UsageError("manifest schemaVersion must be 1")
    raw_sources = payload.get("sources")
    if not isinstance(raw_sources, list) or not raw_sources:
        raise UsageError("manifest sources must be a non-empty array")
    sources: list[Source] = []
    seen: set[str] = set()
    for index, item in enumerate(raw_sources):
        if not isinstance(item, dict):
            raise UsageError(f"manifest sources[{index}] must be an object")
        identifier = item.get("id")
        repository = item.get("repository")
        branch = item.get("branch")
        role = item.get("role")
        include = item.get("include")
        if not isinstance(identifier, str) or not re.fullmatch(r"[a-z0-9-]+", identifier):
            raise UsageError(f"manifest sources[{index}].id must be lower-case hyphenated text")
        if identifier in seen:
            raise UsageError(f"manifest source id is duplicated: {identifier}")
        if not all(isinstance(value, str) and value for value in (repository, branch, role)):
            raise UsageError(f"manifest source {identifier} requires repository, branch, and role")
        if not isinstance(include, list) or not include or not all(isinstance(value, str) and value for value in include):
            raise UsageError(f"manifest source {identifier}.include must be a non-empty string array")
        seen.add(identifier)
        sources.append(Source(identifier, repository, branch, role, tuple(include)))
    return sources


def select_sources(sources: Sequence[Source], requested: Sequence[str]) -> list[Source]:
    if not requested:
        return list(sources)
    known = {source.id: source for source in sources}
    unknown = sorted(set(requested) - set(known))
    if unknown:
        raise UsageError(f"unknown source: {', '.join(unknown)}")
    return [known[identifier] for identifier in dict.fromkeys(requested)]


def home() -> int:
    sources = load_sources(DEFAULT_MANIFEST)
    emit(
        {
            "bin": collapse_home(Path(__file__).resolve()),
            "description": DESCRIPTION,
            "source_count": len(sources),
            "help": [
                "Run `pkl_sources catalog` to route to an official repository",
                "Run `pkl_sources sync --cache <dir>` to fetch declared sources",
                "Run `pkl_sources index --cache <dir> --out <file>` after sync",
            ],
        }
    )
    return 0


def run_catalog(args: argparse.Namespace) -> int:
    sources = select_sources(load_sources(args.manifest), args.source)
    emit(
        {
            "source_count": len(sources),
            "sources": [
                {"id": source.id, "role": source.role, "repository": source.repository}
                for source in sources
            ],
            "help": ["Run `pkl_sources sync --cache <dir> --source <id>` to fetch one source"],
        }
    )
    return 0


def is_local_repository(value: str) -> bool:
    return not value.startswith(("https://", "http://", "ssh://", "git@"))


def run_git(args: Sequence[str], *, cwd: Path | None = None) -> str:
    completed = subprocess.run(
        ["git", *args],
        cwd=cwd,
        text=True,
        capture_output=True,
        check=False,
    )
    if completed.returncode != 0:
        detail = (completed.stderr or completed.stdout).strip() or "git operation failed"
        raise RuntimeError(detail[:1200])
    return completed.stdout.strip()


def ensure_clean_checkout(checkout: Path, source_id: str) -> None:
    status = run_git(["status", "--porcelain", "--untracked-files=all"], cwd=checkout)
    if status:
        raise UsageError(f"source {source_id} checkout has uncommitted changes: {checkout}")


def sync_source(source: Source, cache: Path, allow_local: bool) -> tuple[str, str]:
    local = is_local_repository(source.repository)
    if local and not allow_local:
        raise UsageError(
            f"source {source.id} is local; pass --allow-local-sources only for an explicitly trusted manifest"
        )
    if not local and not source.repository.startswith(FIRST_PARTY_PREFIX):
        raise UsageError(f"source {source.id} is not an approved first-party Apple GitHub repository")
    checkout = cache / source.id
    previous: str | None = None
    if checkout.exists():
        if not (checkout / ".git").exists():
            raise UsageError(f"cache path exists but is not a Git checkout: {checkout}")
        ensure_clean_checkout(checkout, source.id)
        previous = run_git(["rev-parse", "HEAD"], cwd=checkout)
        run_git(["remote", "set-url", "origin", source.repository], cwd=checkout)
        fetch_args = ["fetch", "--quiet", "--depth", "1", "origin"]
        if source.branch != "HEAD":
            fetch_args.append(source.branch)
        run_git(fetch_args, cwd=checkout)
        run_git(["checkout", "--quiet", "--detach", "FETCH_HEAD"], cwd=checkout)
    else:
        clone_args = ["clone", "--quiet", "--depth", "1"]
        if not local:
            clone_args.extend(["--filter=blob:none"])
        if source.branch != "HEAD":
            clone_args.extend(["--branch", source.branch])
        clone_args.extend([source.repository, str(checkout)])
        run_git(clone_args)
    commit = run_git(["rev-parse", "HEAD"], cwd=checkout)
    return commit, "noop" if previous == commit else "updated"


def run_sync(args: argparse.Namespace) -> int:
    sources = select_sources(load_sources(args.manifest), args.source)
    cache = args.cache.expanduser().resolve()
    cache.mkdir(parents=True, exist_ok=True)
    locked: list[dict[str, str]] = []
    statuses: list[dict[str, str]] = []
    for source in sources:
        commit, status = sync_source(source, cache, args.allow_local_sources)
        locked.append(
            {
                "id": source.id,
                "repository": source.repository,
                "branch": source.branch,
                "commit": commit,
            }
        )
        statuses.append({"id": source.id, "status": status, "commit": commit[:12]})
    lock_path = cache / "sources.lock.json"
    write_json(lock_path, {"schemaVersion": 1, "sources": locked})
    emit(
        {
            "status": "synced",
            "cache": collapse_home(cache),
            "source_count": len(sources),
            "sources": statuses,
            "lock": collapse_home(lock_path),
        }
    )
    return 0


def parse_entries(root: Path, source: Source) -> list[dict[str, str]]:
    paths: set[Path] = set()
    for pattern in source.include:
        paths.update(path for path in root.glob(pattern) if path.is_file())
    entries: list[dict[str, str]] = []
    for path in sorted(paths, key=lambda item: item.relative_to(root).as_posix()):
        relative = path.relative_to(root).as_posix()
        try:
            lines = path.read_text(encoding="utf-8", errors="replace").splitlines()
        except OSError:
            continue
        if path.suffix.lower() in {".md", ".adoc", ".asciidoc"}:
            for line in lines:
                match = HEADING_PATTERN.match(line)
                if match:
                    entries.append({"kind": "heading", "path": relative, "name": match.group(1).strip()})
        elif path.suffix == ".pkl" or path.name in {"PklProject", "PklProject.deps.json"}:
            for line in lines:
                for kind, pattern in PKL_PATTERNS:
                    match = pattern.match(line)
                    if match:
                        entries.append({"kind": kind, "path": relative, "name": match.group(1)})
                        break
    return entries


def run_index(args: argparse.Namespace) -> int:
    sources = select_sources(load_sources(args.manifest), args.source)
    cache = args.cache.expanduser().resolve()
    lock_path = cache / "sources.lock.json"
    try:
        lock = json.loads(lock_path.read_text(encoding="utf-8"))
    except FileNotFoundError as error:
        raise UsageError(f"sync lock does not exist: {lock_path}; run sync first") from error
    except json.JSONDecodeError as error:
        raise UsageError(f"sync lock is not valid JSON: {lock_path}") from error
    locked = {item.get("id"): item for item in lock.get("sources", []) if isinstance(item, dict)}
    indexed: list[dict[str, Any]] = []
    total_entries = 0
    for source in sources:
        lock_entry = locked.get(source.id)
        if not isinstance(lock_entry, dict) or not isinstance(lock_entry.get("commit"), str):
            raise UsageError(f"source {source.id} is not present in {lock_path}; sync it first")
        checkout = cache / source.id
        ensure_clean_checkout(checkout, source.id)
        actual_commit = run_git(["rev-parse", "HEAD"], cwd=checkout)
        if actual_commit != lock_entry["commit"]:
            raise UsageError(f"source {source.id} checkout does not match the recorded lock commit")
        entries = parse_entries(checkout, source)
        total_entries += len(entries)
        indexed.append(
            {
                "id": source.id,
                "repository": source.repository,
                "commit": actual_commit,
                "entries": entries,
            }
        )
    output = args.out.expanduser().resolve()
    write_json(output, {"schemaVersion": 1, "sources": indexed})
    emit(
        {
            "status": "indexed",
            "source_count": len(indexed),
            "entry_count": total_entries,
            "output": collapse_home(output),
        }
    )
    return 0


def write_json(path: Path, payload: Mapping[str, Any]) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    temporary = path.with_name(path.name + ".tmp")
    temporary.write_text(json.dumps(payload, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
    os.replace(temporary, path)


def collapse_home(path: Path | str) -> str:
    value = str(path)
    home = str(Path.home())
    return "~" + value[len(home) :] if value == home or value.startswith(home + os.sep) else value


def main(argv: Sequence[str] | None = None) -> int:
    parser = build_parser()
    try:
        args = parser.parse_args(argv)
        if args.command is None:
            return home()
        if args.command == "catalog":
            return run_catalog(args)
        if args.command == "sync":
            return run_sync(args)
        if args.command == "index":
            return run_index(args)
        raise UsageError(f"unknown command: {args.command}")
    except UsageError as error:
        emit({"error": str(error), "help": "Run `pkl_sources --help` for valid commands and flags"})
        return 2
    except (OSError, RuntimeError) as error:
        emit({"error": str(error), "help": "Inspect the manifest, cache path, network, and Git credentials"})
        return 1


if __name__ == "__main__":
    raise SystemExit(main())
