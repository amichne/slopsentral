{
  "$schema": "https://json.schemastore.org/codex-hooks.json",
  "description": "Run the Kotlin horizontalization layout gate at turn end for changed Kotlin files.",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/kotlin-horizontalization-check.py --repo .",
            "timeout": 30,
            "statusMessage": "Checking Kotlin package layout"
          }
        ]
      }
    ]
  }
}
