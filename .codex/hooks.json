{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash source/hooks/agents-md-turn-refresh.sh start --repo .",
            "timeout": 10,
            "statusMessage": "Starting AGENTS.md turn tracking"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash source/hooks/agents-md-turn-refresh.sh record --repo .",
            "timeout": 10,
            "statusMessage": "Recording AGENTS.md turn edits"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash source/hooks/agents-md-turn-refresh.sh stop --repo .",
            "timeout": 30,
            "statusMessage": "Checking affected AGENTS.md files"
          }
        ]
      }
    ]
  }
}
